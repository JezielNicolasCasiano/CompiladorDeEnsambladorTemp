<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<AnchorPane prefHeight="551.0" prefWidth="884.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="jeziel.compiladordeensamblador.controlador.Controlador">
   <children>
      <BorderPane prefHeight="551.0" prefWidth="884.0">
         <top>
            <MenuBar fx:id="menu" BorderPane.alignment="CENTER">
              <menus>
                <Menu mnemonicParsing="false" text="File">
                  <items>
                    <MenuItem fx:id="seleccionarArchivo" mnemonicParsing="false" onAction="#SeleccionarUnArchivo" text="Seleccionar" />
                  </items>
                </Menu>
              </menus>
            </MenuBar>
         </top>
         <left>
            <ScrollPane fx:id="codigoScrollPane" prefHeight="524.0" prefWidth="332.0" BorderPane.alignment="CENTER">
              <content>
                <AnchorPane fx:id="codigoAnchor" minHeight="0.0" minWidth="0.0" prefHeight="521.0" prefWidth="330.0">
                     <children>
                        <TextArea fx:id="codigoArea" prefHeight="523.0" prefWidth="330.0" styleClass="content" />
                     </children></AnchorPane>
              </content>
            </ScrollPane>
         </left>
         <right>
            <ScrollPane fx:id="codigoSeparadoScrollPane" prefHeight="524.0" prefWidth="315.0" BorderPane.alignment="CENTER">
              <content>
                <AnchorPane fx:id="codigoSeparadoAnchor" minHeight="0.0" minWidth="0.0" prefHeight="521.0" prefWidth="313.0" />
              </content>
            </ScrollPane>
         </right>
         <center>
            <ScrollPane fx:id="contadorScrollPane" prefHeight="524.0" prefWidth="307.0" BorderPane.alignment="CENTER">
              <content>
                <AnchorPane fx:id="contadorAnchor" minHeight="0.0" minWidth="0.0" prefHeight="522.0" prefWidth="235.0" />
              </content>
            </ScrollPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
