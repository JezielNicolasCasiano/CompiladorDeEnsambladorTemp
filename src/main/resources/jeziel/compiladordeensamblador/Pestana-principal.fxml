<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<AnchorPane prefHeight="551.0" prefWidth="884.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="jeziel.compiladordeensamblador.controlador.Controlador">
   <children>
      <BorderPane prefHeight="551.0" prefWidth="884.0">
         <top>
            <MenuBar fx:id="menu" BorderPane.alignment="CENTER">
              <menus>
                <Menu mnemonicParsing="false" text="File">
                  <items>
                    <MenuItem fx:id="seleccionarArchivo" mnemonicParsing="false" onAction="#SeleccionarUnArchivo" text="Seleccionar" />
                  </items>
                </Menu>
              </menus>
            </MenuBar>
         </top>
         <left>
            <ScrollPane fx:id="codigoScrollPane" prefHeight="524.0" prefWidth="448.0" BorderPane.alignment="CENTER">
              <content>
                <AnchorPane fx:id="codigoAnchor" minHeight="0.0" minWidth="0.0" prefHeight="521.0" prefWidth="445.0">
                     <children>
                        <TextArea fx:id="codigoArea" prefHeight="523.0" prefWidth="446.0" styleClass="content" />
                     </children></AnchorPane>
              </content>
            </ScrollPane>
         </left>
         <right>
            <Pagination fx:id="divisionPagina" prefHeight="524.0" prefWidth="395.0" stylesheets="@estilos.css" BorderPane.alignment="CENTER">
               <styleClass>
                  <String fx:value="control-box" />
                  <String fx:value="bullet-button" />
                  <String fx:value="number-button" />
               </styleClass>
            </Pagination>
         </right>
         <center>
            <Pagination fx:id="numeracionPagina" prefHeight="524.0" prefWidth="61.0" BorderPane.alignment="CENTER" />
         </center>
      </BorderPane>
   </children>
</AnchorPane>
